# AMQP connection-URI dictionary (fuzz_url -> amqp_parse_url).
# amqp_parse_url branches on the "amqp://" / "amqps://" scheme then splits
# user:pass@host:port/vhost; these tokens drive its parser.
scheme_amqp="amqp://"
scheme_amqps="amqps://"
at="@"
colon=":"
slash="/"
userinfo="user:pass@"
host="host"
port=":5672"
vhost="/vhost"
percent="%2f"
ipv6="[::1]"
empty_vhost="amqp:///"
default="amqp://guest:guest@localhost:5672/"
